<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:StudentOnboardingApp.Views"
       x:Class="StudentOnboardingApp.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False">

    <!-- Auth Flow (no tabs) -->
    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />

    <!-- Main App with Tabs -->
    <TabBar Route="main">
        <ShellContent Route="dashboard" Title="Home" ContentTemplate="{DataTemplate views:DashboardPage}" />
        <ShellContent Route="profile" Title="Profile" ContentTemplate="{DataTemplate views:ProfilePage}" />
    </TabBar>

</Shell>
