<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Brand Colors (matching student_onboard website) -->
    <Color x:Key="Primary">#5B5BD6</Color>
    <Color x:Key="PrimaryDark">#4747C2</Color>
    <Color x:Key="PrimaryLight">#7B7DE0</Color>
    <Color x:Key="Secondary">#8B8FD4</Color>
    <Color x:Key="Tertiary">#C4C3E8</Color>

    <!-- Accent Colors -->
    <Color x:Key="Blush">#F5D7F0</Color>
    <Color x:Key="BlushDeep">#EBBFE5</Color>

    <!-- Surface Colors -->
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Surface2">#F8F7FF</Color>
    <Color x:Key="Surface3">#F0EFFE</Color>
    <Color x:Key="BackgroundGradientStart">#F5D7F0</Color>
    <Color x:Key="BackgroundGradientMid">#C4C3E8</Color>
    <Color x:Key="BackgroundGradientEnd">#8B8FD4</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#1A1A3E</Color>
    <Color x:Key="TextSecondary">#5A5A82</Color>
    <Color x:Key="TextMuted">#9898B8</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Border Colors -->
    <Color x:Key="Border">#E4E2F8</Color>
    <Color x:Key="BorderLight">#EEEDFB</Color>

    <!-- Status Colors -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="SuccessLight">#DCFCE7</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerLight">#FEE2E2</Color>
    <Color x:Key="Info">#3B82F6</Color>
    <Color x:Key="InfoLight">#DBEAFE</Color>

    <!-- Transparent overlays -->
    <Color x:Key="Overlay">#40000000</Color>
    <Color x:Key="CardShadow">#145B5BD6</Color>

</ResourceDictionary>
