<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ==================== LABEL STYLES ==================== -->

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="Heading1" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaExtraBold" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="Heading2" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaBold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="Heading3" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="Subtitle" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaMedium" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="Body" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodySmall" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="Caption" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSansMedium" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="CharacterSpacing" Value="0.8" />
    </Style>

    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="Margin" Value="4,2,0,0" />
    </Style>

    <!-- ==================== ENTRY STYLES ==================== -->

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="DMSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <!-- ==================== BUTTON STYLES ==================== -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface3}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style x:Key="TextButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="JakartaSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- ==================== FRAME / CARD STYLES ==================== -->

    <Style x:Key="Card" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="BorderColor" Value="{StaticResource BorderLight}" />
    </Style>

    <Style x:Key="CardElevated" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

    <!-- ==================== INPUT FRAME (wraps Entry for styled inputs) ==================== -->

    <Style x:Key="InputFrame" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource Border}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Padding" Value="16,4" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== ACTIVITY INDICATOR ==================== -->

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <!-- ==================== NAVIGATION / SHELL ==================== -->

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource TextMuted}" />
