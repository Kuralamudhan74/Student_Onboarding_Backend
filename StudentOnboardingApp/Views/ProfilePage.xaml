<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:converters="clr-namespace:StudentOnboardingApp.Converters"
             x:Class="StudentOnboardingApp.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface2}">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:BoolToColorConverter x:Key="BoolToColor" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Profile Header -->
            <Grid HeightRequest="260" Padding="24,0">
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <Ellipse WidthRequest="200" HeightRequest="200" Fill="#08FFFFFF"
                         HorizontalOptions="End" VerticalOptions="Start"
                         TranslationX="60" TranslationY="-40" />

                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     Spacing="12" Padding="0,30,0,0">
                    <!-- Avatar -->
                    <Border WidthRequest="80" HeightRequest="80"
                            BackgroundColor="#30FFFFFF"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="40" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#305B5BD6" Offset="0,4" Radius="16" Opacity="0.3" />
                        </Border.Shadow>
                        <Label Text="{Binding Initials}"
                               FontFamily="JakartaBold" FontSize="28"
                               TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Label x:Name="NameLabel"
                           Text="{Binding FullName}"
                           FontFamily="JakartaBold" FontSize="22"
                           TextColor="White"
                           HorizontalOptions="Center"
                           Opacity="0" />

                    <!-- Role Badge -->
                    <Border BackgroundColor="#20FFFFFF"
                            Padding="14,6"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding Role}"
                               FontFamily="JakartaMedium" FontSize="13"
                               TextColor="White" />
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Content -->
            <VerticalStackLayout Padding="20,0,20,24" Spacing="16" Margin="0,-20,0,0">

                <!-- Info Card -->
                <Border x:Name="InfoCard"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20" Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Account Information"
                               Style="{StaticResource Heading3}" />

                        <!-- Email -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="EMAIL" Style="{StaticResource Caption}" />
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Email}"
                                       FontFamily="DMSansMedium" FontSize="15" />
                                <Border Grid.Column="1"
                                        Padding="8,3"
                                        BackgroundColor="{Binding EmailVerified, Converter={StaticResource BoolToColor}, ConverterParameter=SuccessLight}"
                                        IsVisible="{Binding EmailVerified}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label Text="Verified"
                                           FontFamily="JakartaSemiBold" FontSize="10"
                                           TextColor="{StaticResource Success}" />
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderLight}" />

                        <!-- Phone -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="PHONE" Style="{StaticResource Caption}" />
                            <Label Text="{Binding PhoneNumber}"
                                   FontFamily="DMSansMedium" FontSize="15" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Security Card -->
                <Border x:Name="SecurityCard"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20" Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Security" Style="{StaticResource Heading3}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource TextButton}"
                                    FontSize="13"
                                    Command="{Binding ToggleChangePasswordCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding ShowChangePassword}" Value="True">
                                        <Setter Property="Text" Value="Cancel" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding ShowChangePassword}" Value="False">
                                        <Setter Property="Text" Value="Change Password" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>

                        <!-- Change Password Form -->
                        <VerticalStackLayout IsVisible="{Binding ShowChangePassword}" Spacing="14">

                            <!-- Message -->
                            <Border Padding="12,10" IsVisible="False" x:Name="PasswordMsgBorder">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Label Text="{Binding PasswordMessage}" FontSize="13"
                                       HorizontalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="CURRENT PASSWORD" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="Enter current password"
                                           Text="{Binding CurrentPassword}"
                                           IsPassword="True" ReturnType="Next" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="NEW PASSWORD" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="Enter new password"
                                           Text="{Binding NewPassword}"
                                           IsPassword="True" ReturnType="Next" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="CONFIRM NEW PASSWORD" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="Confirm new password"
                                           Text="{Binding ConfirmNewPassword}"
                                           IsPassword="True" ReturnType="Done" />
                                </Border>
                            </VerticalStackLayout>

                            <Button Text="Update Password"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ChangePasswordCommand}"
                                    IsEnabled="{Binding IsChangingPassword, Converter={StaticResource InverseBool}}" />
                        </VerticalStackLayout>

                        <!-- Security info when form hidden -->
                        <VerticalStackLayout IsVisible="{Binding ShowChangePassword, Converter={StaticResource InverseBool}}" Spacing="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="🔒" FontSize="16" />
                                <Label Text="Password protected account"
                                       Style="{StaticResource BodySmall}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="🛡️" FontSize="16" />
                                <Label Text="JWT token authentication"
                                       Style="{StaticResource BodySmall}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Logout Button -->
                <Button x:Name="LogoutButton"
                        Text="Sign Out"
                        Style="{StaticResource SecondaryButton}"
                        TextColor="{StaticResource Danger}"
                        Command="{Binding LogoutCommand}"
                        Margin="0,8,0,0"
                        Opacity="0" />

                <Label Text="Student Onboarding Platform v1.0"
                       Style="{StaticResource Caption}"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
