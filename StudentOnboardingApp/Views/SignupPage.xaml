<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:converters="clr-namespace:StudentOnboardingApp.Converters"
             x:Class="StudentOnboardingApp.Views.SignupPage"
             x:DataType="vm:SignupViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:BoolToColorConverter x:Key="BoolToColor" />
    </ContentPage.Resources>

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource BackgroundGradientStart}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BackgroundGradientMid}" Offset="0.5" />
                    <GradientStop Color="{StaticResource BackgroundGradientEnd}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Decorative circles -->
        <Ellipse WidthRequest="180" HeightRequest="180" Fill="#18FFFFFF"
                 HorizontalOptions="End" VerticalOptions="Start"
                 TranslationX="50" TranslationY="-30" />
        <Ellipse WidthRequest="120" HeightRequest="120" Fill="#12FFFFFF"
                 HorizontalOptions="Start" VerticalOptions="End"
                 TranslationX="-30" TranslationY="40" />

        <ScrollView>
            <VerticalStackLayout Padding="24,48,24,24" Spacing="0" MaximumWidthRequest="420">

                <!-- Header -->
                <VerticalStackLayout x:Name="HeaderArea" Spacing="8" Padding="0,0,0,24" Opacity="0">
                    <Label Text="🚀" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Create Account"
                           Style="{StaticResource Heading2}"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Join us and start your learning journey"
                           Style="{StaticResource Subtitle}"
                           TextColor="#DDFFFFFF"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Signup Card -->
                <Border x:Name="SignupCard"
                        BackgroundColor="#E8FFFFFF"
                        StrokeThickness="1"
                        Stroke="#40FFFFFF"
                        Padding="24,28"
                        Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#305B5BD6" Offset="0,12" Radius="40" Opacity="0.22" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!-- Error -->
                        <Border BackgroundColor="{StaticResource DangerLight}"
                                Stroke="{StaticResource Danger}" StrokeThickness="1"
                                Padding="12,10"
                                IsVisible="False"
                                x:Name="ErrorBorder">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}"
                                   Style="{StaticResource ErrorLabel}" FontSize="13"
                                   HorizontalOptions="Center" />
                        </Border>

                        <!-- Name Row -->
                        <Grid ColumnDefinitions="*,12,*">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="FIRST NAME" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="First name"
                                           Text="{Binding FirstName}"
                                           ReturnType="Next" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="6">
                                <Label Text="LAST NAME" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="Last name"
                                           Text="{Binding LastName}"
                                           ReturnType="Next" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="EMAIL" Style="{StaticResource Caption}" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry Placeholder="your@email.com"
                                       Text="{Binding Email}"
                                       Keyboard="Email"
                                       ReturnType="Next" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Phone -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="PHONE NUMBER" Style="{StaticResource Caption}" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry Placeholder="+91 XXXXX XXXXX"
                                       Text="{Binding PhoneNumber}"
                                       Keyboard="Telephone"
                                       ReturnType="Next" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="PASSWORD" Style="{StaticResource Caption}" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry Placeholder="Create a strong password"
                                       Text="{Binding Password}"
                                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBool}}"
                                       ReturnType="Next" />
                            </Border>

                            <!-- Password strength indicators -->
                            <FlexLayout Wrap="Wrap" JustifyContent="Start" Margin="4,4,0,0">
                                <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                    <Label Text="●" FontSize="8"
                                           TextColor="{Binding HasMinLength, Converter={StaticResource BoolToColor}}" />
                                    <Label Text="8+ chars" Style="{StaticResource Caption}" FontSize="11" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                    <Label Text="●" FontSize="8"
                                           TextColor="{Binding HasUppercase, Converter={StaticResource BoolToColor}}" />
                                    <Label Text="Uppercase" Style="{StaticResource Caption}" FontSize="11" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                    <Label Text="●" FontSize="8"
                                           TextColor="{Binding HasLowercase, Converter={StaticResource BoolToColor}}" />
                                    <Label Text="Lowercase" Style="{StaticResource Caption}" FontSize="11" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                    <Label Text="●" FontSize="8"
                                           TextColor="{Binding HasDigit, Converter={StaticResource BoolToColor}}" />
                                    <Label Text="Number" Style="{StaticResource Caption}" FontSize="11" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                    <Label Text="●" FontSize="8"
                                           TextColor="{Binding HasSpecialChar, Converter={StaticResource BoolToColor}}" />
                                    <Label Text="Special" Style="{StaticResource Caption}" FontSize="11" />
                                </HorizontalStackLayout>
                            </FlexLayout>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="CONFIRM PASSWORD" Style="{StaticResource Caption}" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry Placeholder="Confirm your password"
                                       Text="{Binding ConfirmPassword}"
                                       IsPassword="True"
                                       ReturnType="Done" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Signup Button -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding SignupCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Margin="0,8,0,0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Text" Value="Creating account..." />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="False">
                                    <Setter Property="Text" Value="Create Account" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <!-- Login Link -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Already have an account?"
                                   Style="{StaticResource BodySmall}"
                                   VerticalOptions="Center" />
                            <Button Text="Sign In"
                                    Style="{StaticResource TextButton}"
                                    FontSize="15"
                                    Command="{Binding GoToLoginCommand}" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
