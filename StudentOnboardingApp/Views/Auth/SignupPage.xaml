<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels.Auth"
             x:Class="StudentOnboardingApp.Views.Auth.SignupPage"
             x:DataType="vm:SignupViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource LightBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="30,20">

            <Label Text="Create Account"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" />

            <Label Text="Fill in the details below to get started"
                   FontSize="14"
                   TextColor="{StaticResource Gray500}"
                   HorizontalOptions="Center" />

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource ErrorRed}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   HorizontalOptions="Center"
                   FontSize="13" />

            <!-- First Name -->
            <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
                <Entry Placeholder="First Name" Text="{Binding FirstName}" ReturnType="Next" />
            </Border>

            <!-- Last Name -->
            <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
                <Entry Placeholder="Last Name" Text="{Binding LastName}" ReturnType="Next" />
            </Border>

            <!-- Email -->
            <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
                <Entry Placeholder="Email Address" Text="{Binding Email}" Keyboard="Email" ReturnType="Next" />
            </Border>

            <!-- Phone -->
            <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
                <Entry Placeholder="Phone Number" Text="{Binding PhoneNumber}" Keyboard="Telephone" ReturnType="Next" />
            </Border>

            <!-- Course Picker -->
            <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
                <Picker Title="Select a Course"
                        ItemsSource="{Binding Courses}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedCourse}" />
            </Border>

            <!-- Password -->
            <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
                <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" ReturnType="Next" />
            </Border>

            <!-- Confirm Password -->
            <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
                <Entry Placeholder="Confirm Password" Text="{Binding ConfirmPassword}" IsPassword="True" ReturnType="Done" />
            </Border>

            <!-- Signup Button -->
            <Button Text="Sign Up"
                    Command="{Binding SignupCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="50"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" HorizontalOptions="Center" />

            <!-- Login Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Already have an account?" TextColor="{StaticResource Gray500}" FontSize="13" />
                <Label Text="Login" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="13">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
