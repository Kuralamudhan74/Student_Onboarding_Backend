<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels.Auth"
             x:Class="StudentOnboardingApp.Views.Auth.OtpVerificationPage"
             x:DataType="vm:OtpVerificationViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource LightBackground}">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Label Text="Verify OTP"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="{StaticResource Primary}"
               HorizontalOptions="Center" />

        <Label FontSize="14"
               TextColor="{StaticResource Gray500}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Enter the 6-digit code sent to " />
                    <Span Text="{Binding Email}" FontAttributes="Bold" TextColor="{StaticResource DarkText}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <!-- Error -->
        <Label Text="{Binding ErrorMessage}"
               TextColor="{StaticResource ErrorRed}"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
               HorizontalOptions="Center"
               FontSize="13" />

        <!-- OTP Entry -->
        <Border Stroke="{StaticResource Gray200}" StrokeShape="RoundRectangle 12" Padding="12,4">
            <Entry Placeholder="Enter 6-digit OTP"
                   Text="{Binding OtpCode}"
                   Keyboard="Numeric"
                   MaxLength="6"
                   HorizontalTextAlignment="Center"
                   FontSize="24"
                   CharacterSpacing="8"
                   ReturnType="Done" />
        </Border>

        <!-- Verify Button -->
        <Button Text="Verify"
                Command="{Binding VerifyCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="12"
                HeightRequest="50"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" HorizontalOptions="Center" />

        <!-- Resend -->
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
            <Label Text="Didn't receive the code?" TextColor="{StaticResource Gray500}" FontSize="13" />
            <Label TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="13"
                   IsVisible="{Binding CanResend}">
                <Label.Text>Resend</Label.Text>
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ResendOtpCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <Label Text="{Binding ResendCountdown, StringFormat='Resend in {0}s'}"
                   TextColor="{StaticResource Gray400}"
                   FontSize="13"
                   IsVisible="{Binding CanResend, Converter={StaticResource InverseBoolConverter}}" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>
