<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:converters="clr-namespace:StudentOnboardingApp.Converters"
             x:Class="StudentOnboardingApp.Views.OtpVerificationPage"
             x:DataType="vm:OtpVerificationViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </ContentPage.Resources>

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource BackgroundGradientStart}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BackgroundGradientMid}" Offset="0.5" />
                    <GradientStop Color="{StaticResource BackgroundGradientEnd}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="24" Spacing="0" MaximumWidthRequest="420">

                <!-- Header -->
                <VerticalStackLayout x:Name="HeaderArea" Spacing="8" Padding="0,0,0,32" Opacity="0">
                    <Label Text="📧" FontSize="56" HorizontalOptions="Center" />
                    <Label Text="Check Your Email"
                           Style="{StaticResource Heading2}"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label HorizontalOptions="Center"
                           Style="{StaticResource Subtitle}"
                           TextColor="#DDFFFFFF"
                           HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="We sent a 6-digit code to " />
                                <Span Text="{Binding Email}" FontFamily="JakartaSemiBold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>

                <!-- OTP Card -->
                <Border x:Name="OtpCard"
                        BackgroundColor="#E8FFFFFF"
                        StrokeThickness="1"
                        Stroke="#40FFFFFF"
                        Padding="28,32"
                        Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#305B5BD6" Offset="0,12" Radius="40" Opacity="0.22" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <Label Text="Enter Verification Code"
                               Style="{StaticResource Heading3}"
                               HorizontalOptions="Center" />

                        <!-- Error/Success Messages -->
                        <Border BackgroundColor="{StaticResource DangerLight}"
                                Stroke="{StaticResource Danger}" StrokeThickness="1"
                                Padding="12,10" IsVisible="False" x:Name="ErrorBorder">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="{StaticResource Danger}" FontSize="13"
                                   HorizontalOptions="Center" />
                        </Border>

                        <Border BackgroundColor="{StaticResource SuccessLight}"
                                Stroke="{StaticResource Success}" StrokeThickness="1"
                                Padding="12,10" IsVisible="False" x:Name="SuccessBorder">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding SuccessMessage}"
                                   TextColor="{StaticResource Success}" FontSize="13"
                                   HorizontalOptions="Center" />
                        </Border>

                        <!-- OTP Input Boxes -->
                        <Grid ColumnDefinitions="*,*,*,*,*,*"
                              ColumnSpacing="8"
                              HorizontalOptions="Center"
                              MaximumWidthRequest="320">
                            <Border Style="{StaticResource InputFrame}" Padding="0" HeightRequest="56">
                                <Entry Text="{Binding Digit1}" MaxLength="1" Keyboard="Numeric"
                                       HorizontalTextAlignment="Center" FontSize="22"
                                       FontFamily="JakartaBold" />
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource InputFrame}" Padding="0" HeightRequest="56">
                                <Entry Text="{Binding Digit2}" MaxLength="1" Keyboard="Numeric"
                                       HorizontalTextAlignment="Center" FontSize="22"
                                       FontFamily="JakartaBold" />
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource InputFrame}" Padding="0" HeightRequest="56">
                                <Entry Text="{Binding Digit3}" MaxLength="1" Keyboard="Numeric"
                                       HorizontalTextAlignment="Center" FontSize="22"
                                       FontFamily="JakartaBold" />
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource InputFrame}" Padding="0" HeightRequest="56">
                                <Entry Text="{Binding Digit4}" MaxLength="1" Keyboard="Numeric"
                                       HorizontalTextAlignment="Center" FontSize="22"
                                       FontFamily="JakartaBold" />
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource InputFrame}" Padding="0" HeightRequest="56">
                                <Entry Text="{Binding Digit5}" MaxLength="1" Keyboard="Numeric"
                                       HorizontalTextAlignment="Center" FontSize="22"
                                       FontFamily="JakartaBold" />
                            </Border>
                            <Border Grid.Column="5" Style="{StaticResource InputFrame}" Padding="0" HeightRequest="56">
                                <Entry Text="{Binding Digit6}" MaxLength="1" Keyboard="Numeric"
                                       HorizontalTextAlignment="Center" FontSize="22"
                                       FontFamily="JakartaBold" />
                            </Border>
                        </Grid>

                        <!-- Verify Button -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding VerifyOtpCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Text" Value="Verifying..." />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="False">
                                    <Setter Property="Text" Value="Verify Code" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <!-- Resend -->
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Didn't receive the code?"
                                   Style="{StaticResource BodySmall}"
                                   HorizontalOptions="Center" />
                            <Button Style="{StaticResource TextButton}"
                                    Command="{Binding ResendOtpCommand}"
                                    IsEnabled="{Binding CanResend}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding CanResend}" Value="True">
                                        <Setter Property="Text" Value="Resend Code" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding CanResend}" Value="False">
                                        <Setter Property="Text" Value="Resend in {Binding ResendCountdown}s" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
