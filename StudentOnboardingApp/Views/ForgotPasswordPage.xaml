<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:converters="clr-namespace:StudentOnboardingApp.Converters"
             x:Class="StudentOnboardingApp.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </ContentPage.Resources>

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource BackgroundGradientStart}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BackgroundGradientMid}" Offset="0.5" />
                    <GradientStop Color="{StaticResource BackgroundGradientEnd}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="24" Spacing="0" MaximumWidthRequest="420">

                <!-- Back button -->
                <Button Text="← Back"
                        Style="{StaticResource TextButton}"
                        TextColor="White"
                        HorizontalOptions="Start"
                        Margin="0,0,0,16"
                        Command="{Binding GoBackCommand}" />

                <!-- Header -->
                <VerticalStackLayout x:Name="HeaderArea" Spacing="8" Padding="0,0,0,32" Opacity="0">
                    <Label Text="🔒" FontSize="56" HorizontalOptions="Center" />
                    <Label Text="Forgot Password?"
                           Style="{StaticResource Heading2}"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="No worries! Enter your email and we'll send you a reset code."
                           Style="{StaticResource Subtitle}"
                           TextColor="#DDFFFFFF"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Card -->
                <Border x:Name="FormCard"
                        BackgroundColor="#E8FFFFFF"
                        StrokeThickness="1" Stroke="#40FFFFFF"
                        Padding="28,32"
                        Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#305B5BD6" Offset="0,12" Radius="40" Opacity="0.22" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <!-- Success state -->
                        <VerticalStackLayout IsVisible="{Binding EmailSent}" Spacing="12"
                                             HorizontalOptions="Center">
                            <Label Text="✅" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="Reset code sent!"
                                   Style="{StaticResource Heading3}"
                                   HorizontalOptions="Center" />
                            <Label Text="Redirecting to verification..."
                                   Style="{StaticResource BodySmall}"
                                   HorizontalOptions="Center" />
                            <ActivityIndicator IsRunning="True" HeightRequest="30" />
                        </VerticalStackLayout>

                        <!-- Form state -->
                        <VerticalStackLayout IsVisible="{Binding EmailSent, Converter={StaticResource InverseBool}}"
                                             Spacing="20">

                            <!-- Error -->
                            <Border BackgroundColor="{StaticResource DangerLight}"
                                    Stroke="{StaticResource Danger}" StrokeThickness="1"
                                    Padding="12,10" IsVisible="False" x:Name="ErrorBorder">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Label Text="{Binding ErrorMessage}"
                                       TextColor="{StaticResource Danger}" FontSize="13"
                                       HorizontalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="EMAIL ADDRESS" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="Enter your registered email"
                                           Text="{Binding Email}"
                                           Keyboard="Email"
                                           ReturnType="Done" />
                                </Border>
                            </VerticalStackLayout>

                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SendResetEmailCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Text" Value="Sending..." />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="False">
                                        <Setter Property="Text" Value="Send Reset Code" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
