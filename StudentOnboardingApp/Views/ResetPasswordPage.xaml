<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:converters="clr-namespace:StudentOnboardingApp.Converters"
             x:Class="StudentOnboardingApp.Views.ResetPasswordPage"
             x:DataType="vm:ResetPasswordViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:BoolToColorConverter x:Key="BoolToColor" />
    </ContentPage.Resources>

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource BackgroundGradientStart}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BackgroundGradientMid}" Offset="0.5" />
                    <GradientStop Color="{StaticResource BackgroundGradientEnd}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="24" Spacing="0" MaximumWidthRequest="420">

                <VerticalStackLayout x:Name="HeaderArea" Spacing="8" Padding="0,0,0,32" Opacity="0">
                    <Label Text="🔐" FontSize="56" HorizontalOptions="Center" />
                    <Label Text="New Password"
                           Style="{StaticResource Heading2}"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Create a strong password for your account"
                           Style="{StaticResource Subtitle}"
                           TextColor="#DDFFFFFF"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Border x:Name="FormCard"
                        BackgroundColor="#E8FFFFFF"
                        StrokeThickness="1" Stroke="#40FFFFFF"
                        Padding="28,32" Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#305B5BD6" Offset="0,12" Radius="40" Opacity="0.22" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <!-- Success state -->
                        <VerticalStackLayout IsVisible="{Binding ResetSuccess}" Spacing="12"
                                             HorizontalOptions="Center">
                            <Label Text="🎉" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="Password Reset!"
                                   Style="{StaticResource Heading3}"
                                   HorizontalOptions="Center" />
                            <Label Text="Redirecting to login..."
                                   Style="{StaticResource BodySmall}"
                                   HorizontalOptions="Center" />
                            <ActivityIndicator IsRunning="True" HeightRequest="30" />
                        </VerticalStackLayout>

                        <!-- Form -->
                        <VerticalStackLayout IsVisible="{Binding ResetSuccess, Converter={StaticResource InverseBool}}"
                                             Spacing="20">

                            <Border BackgroundColor="{StaticResource DangerLight}"
                                    Stroke="{StaticResource Danger}" StrokeThickness="1"
                                    Padding="12,10" IsVisible="False" x:Name="ErrorBorder">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Label Text="{Binding ErrorMessage}"
                                       TextColor="{StaticResource Danger}" FontSize="13"
                                       HorizontalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="NEW PASSWORD" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="Enter new password"
                                           Text="{Binding NewPassword}"
                                           IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBool}}"
                                           ReturnType="Next" />
                                </Border>
                                <FlexLayout Wrap="Wrap" JustifyContent="Start" Margin="4,4,0,0">
                                    <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                        <Label Text="●" FontSize="8"
                                               TextColor="{Binding HasMinLength, Converter={StaticResource BoolToColor}}" />
                                        <Label Text="8+ chars" Style="{StaticResource Caption}" FontSize="11" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                        <Label Text="●" FontSize="8"
                                               TextColor="{Binding HasUppercase, Converter={StaticResource BoolToColor}}" />
                                        <Label Text="Upper" Style="{StaticResource Caption}" FontSize="11" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                        <Label Text="●" FontSize="8"
                                               TextColor="{Binding HasLowercase, Converter={StaticResource BoolToColor}}" />
                                        <Label Text="Lower" Style="{StaticResource Caption}" FontSize="11" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                        <Label Text="●" FontSize="8"
                                               TextColor="{Binding HasDigit, Converter={StaticResource BoolToColor}}" />
                                        <Label Text="Number" Style="{StaticResource Caption}" FontSize="11" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4" Margin="0,0,12,4">
                                        <Label Text="●" FontSize="8"
                                               TextColor="{Binding HasSpecialChar, Converter={StaticResource BoolToColor}}" />
                                        <Label Text="Special" Style="{StaticResource Caption}" FontSize="11" />
                                    </HorizontalStackLayout>
                                </FlexLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="CONFIRM PASSWORD" Style="{StaticResource Caption}" />
                                <Border Style="{StaticResource InputFrame}">
                                    <Entry Placeholder="Confirm new password"
                                           Text="{Binding ConfirmPassword}"
                                           IsPassword="True"
                                           ReturnType="Done" />
                                </Border>
                            </VerticalStackLayout>

                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ResetPasswordCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Text" Value="Resetting..." />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="False">
                                        <Setter Property="Text" Value="Reset Password" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
