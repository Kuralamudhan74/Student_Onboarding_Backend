<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             x:Class="StudentOnboardingApp.Views.Courses.CourseDetailPage"
             x:DataType="vm:CourseDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource LightBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" />

            <Border BackgroundColor="{StaticResource ErrorLight}"
                    StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="14,10"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorText}"
                       FontSize="13" HorizontalTextAlignment="Center" />
            </Border>

            <!-- Course Header Card -->
            <Border BackgroundColor="{StaticResource Primary}"
                    StrokeShape="RoundRectangle 18"
                    Padding="24,22"
                    StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#405B5BD6" Offset="0,8" Radius="24" Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding Course.Name}"
                           FontSize="24" FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                    <Label Text="{Binding Course.Description}"
                           FontSize="14" TextColor="#FFFFFFCC" />
                </VerticalStackLayout>
            </Border>

            <!-- Stats Cards -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="14">
                <Border Grid.Column="0" BackgroundColor="White"
                        StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderColor}"
                        Padding="18" StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="#0A5B5BD6" Offset="0,2" Radius="12" Opacity="0.08" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="FEES" FontSize="10" FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextMuted}" CharacterSpacing="0.8" />
                        <Label Text="{Binding Course.Fees, StringFormat='Rs. {0:N0}'}"
                               FontSize="22" FontAttributes="Bold"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="White"
                        StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderColor}"
                        Padding="18" StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="#0A5B5BD6" Offset="0,2" Radius="12" Opacity="0.08" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="DURATION" FontSize="10" FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextMuted}" CharacterSpacing="0.8" />
                        <Label Text="{Binding Course.Duration}"
                               FontSize="22" FontAttributes="Bold"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Syllabus -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                    Stroke="{StaticResource BorderColor}" Padding="20" StrokeThickness="1">
                <Border.Shadow>
                    <Shadow Brush="#0A5B5BD6" Offset="0,2" Radius="12" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Syllabus" FontSize="17" FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource DarkText}" />
                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />
                    <Label Text="{Binding Course.Syllabus}" FontSize="14"
                           TextColor="{StaticResource TextSecondary}" LineHeight="1.5" />
                </VerticalStackLayout>
            </Border>

            <!-- Batch Timings -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                    Stroke="{StaticResource BorderColor}" Padding="20" StrokeThickness="1">
                <Border.Shadow>
                    <Shadow Brush="#0A5B5BD6" Offset="0,2" Radius="12" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Batch Timings" FontSize="17" FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource DarkText}" />
                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />
                    <CollectionView ItemsSource="{Binding Course.BatchTimings}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <HorizontalStackLayout Spacing="10" Padding="0,6">
                                    <Border BackgroundColor="{StaticResource Primary}"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="8" WidthRequest="8"
                                            StrokeThickness="0" VerticalOptions="Center" />
                                    <Label Text="{Binding .}" FontSize="14"
                                           TextColor="{StaticResource TextSecondary}" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Apply Button -->
            <Button Text="Apply for this Course"
                    Command="{Binding ApplyCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontSize="16"
                    Margin="0,10,0,20"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
