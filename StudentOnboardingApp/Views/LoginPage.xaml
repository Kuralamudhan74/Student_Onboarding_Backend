<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:converters="clr-namespace:StudentOnboardingApp.Converters"
             x:Class="StudentOnboardingApp.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </ContentPage.Resources>

    <!-- Gradient Background -->
    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource BackgroundGradientStart}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BackgroundGradientMid}" Offset="0.5" />
                    <GradientStop Color="{StaticResource BackgroundGradientEnd}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Decorative circles (matching website) -->
        <Ellipse WidthRequest="200" HeightRequest="200" Fill="#20FFFFFF"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="-60" TranslationY="-40" />
        <Ellipse WidthRequest="150" HeightRequest="150" Fill="#15FFFFFF"
                 HorizontalOptions="End" VerticalOptions="End"
                 TranslationX="40" TranslationY="60" />
        <Ellipse WidthRequest="100" HeightRequest="100" Fill="#10FFFFFF"
                 HorizontalOptions="Center" VerticalOptions="Start"
                 TranslationY="100" />

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="24" Spacing="0" MaximumWidthRequest="420">

                <!-- Logo / Brand Area -->
                <VerticalStackLayout x:Name="BrandArea" Spacing="8" Padding="0,0,0,32" Opacity="0">
                    <Label Text="🎓" FontSize="56" HorizontalOptions="Center" />
                    <Label Text="Student Onboarding"
                           Style="{StaticResource Heading2}"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Your learning journey begins here"
                           Style="{StaticResource Subtitle}"
                           TextColor="#DDFFFFFF"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Login Card (Glassmorphism) -->
                <Border x:Name="LoginCard"
                        BackgroundColor="#E8FFFFFF"
                        StrokeThickness="1"
                        Stroke="#40FFFFFF"
                        Padding="28,32"
                        Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#305B5BD6" Offset="0,12" Radius="40" Opacity="0.22" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <Label Text="Welcome Back"
                               Style="{StaticResource Heading3}"
                               HorizontalOptions="Center" />
                        <Label Text="Sign in to continue your journey"
                               Style="{StaticResource BodySmall}"
                               HorizontalOptions="Center"
                               Margin="0,-12,0,4" />

                        <!-- Error Message -->
                        <Border BackgroundColor="{StaticResource DangerLight}"
                                Stroke="{StaticResource Danger}"
                                StrokeThickness="1"
                                Padding="12,10"
                                IsVisible="{Binding ErrorMessage, Converter={StaticResource InverseBool}, ConverterParameter=inverse}"
                                x:Name="ErrorBorder">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}"
                                   Style="{StaticResource ErrorLabel}"
                                   FontSize="13"
                                   HorizontalOptions="Center" />
                        </Border>

                        <!-- Email Input -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="EMAIL" Style="{StaticResource Caption}" />
                            <Border Style="{StaticResource InputFrame}">
                                <Entry Placeholder="Enter your email"
                                       Text="{Binding Email}"
                                       Keyboard="Email"
                                       ReturnType="Next" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password Input -->
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="PASSWORD" Style="{StaticResource Caption}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource TextButton}"
                                        FontSize="12"
                                        Command="{Binding TogglePasswordVisibilityCommand}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Text" Value="Hide" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsPasswordVisible}" Value="False">
                                            <Setter Property="Text" Value="Show" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                            <Border Style="{StaticResource InputFrame}">
                                <Entry Placeholder="Enter your password"
                                       Text="{Binding Password}"
                                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBool}}"
                                       ReturnType="Done" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Forgot Password -->
                        <Button Text="Forgot Password?"
                                Style="{StaticResource TextButton}"
                                HorizontalOptions="End"
                                Margin="0,-8,0,0"
                                Command="{Binding GoToForgotPasswordCommand}" />

                        <!-- Login Button -->
                        <Button x:Name="LoginButton"
                                Text="{Binding IsBusy, StringFormat='{0}'}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding IsBusy}"
                                             Value="True">
                                    <Setter Property="Text" Value="Signing in..." />
                                </DataTrigger>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding IsBusy}"
                                             Value="False">
                                    <Setter Property="Text" Value="Sign In" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <!-- Divider -->
                        <Grid ColumnDefinitions="*,Auto,*" Padding="0,4">
                            <BoxView HeightRequest="1" VerticalOptions="Center"
                                     Color="{StaticResource Border}" />
                            <Label Grid.Column="1" Text="  or  "
                                   Style="{StaticResource Caption}" />
                            <BoxView Grid.Column="2" HeightRequest="1"
                                     VerticalOptions="Center"
                                     Color="{StaticResource Border}" />
                        </Grid>

                        <!-- Sign Up Link -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Don't have an account?"
                                   Style="{StaticResource BodySmall}"
                                   VerticalOptions="Center" />
                            <Button Text="Sign Up"
                                    Style="{StaticResource TextButton}"
                                    FontSize="15"
                                    Command="{Binding GoToSignupCommand}" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
