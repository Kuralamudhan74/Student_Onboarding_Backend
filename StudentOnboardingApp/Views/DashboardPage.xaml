<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentOnboardingApp.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="StudentOnboardingApp.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface2}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Top Header with gradient -->
            <Grid HeightRequest="220" Padding="24,0">
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource PrimaryLight}" Offset="0.5" />
                            <GradientStop Color="{StaticResource Secondary}" Offset="1.0" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Decorative circles -->
                <Ellipse WidthRequest="160" HeightRequest="160" Fill="#12FFFFFF"
                         HorizontalOptions="End" VerticalOptions="Start"
                         TranslationX="40" TranslationY="-30" />
                <Ellipse WidthRequest="100" HeightRequest="100" Fill="#10FFFFFF"
                         HorizontalOptions="Start" VerticalOptions="End"
                         TranslationX="-20" TranslationY="20" />

                <VerticalStackLayout VerticalOptions="Center" Spacing="4" Padding="0,20,0,0">
                    <!-- Greeting row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="GreetingLabel"
                                   Text="{Binding Greeting}"
                                   FontFamily="DMSansRegular"
                                   FontSize="15"
                                   TextColor="#CCFFFFFF"
                                   Opacity="0" />
                            <Label x:Name="UserNameLabel"
                                   FontFamily="JakartaBold"
                                   FontSize="26"
                                   TextColor="White"
                                   Opacity="0">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding UserName}" />
                                        <Span Text=" 👋" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>

                        <!-- Avatar -->
                        <Border Grid.Column="1"
                                WidthRequest="48" HeightRequest="48"
                                BackgroundColor="#30FFFFFF"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24" />
                            </Border.StrokeShape>
                            <Label Text="{Binding UserInitials}"
                                   FontFamily="JakartaBold"
                                   FontSize="18"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- Date pill -->
                    <Border BackgroundColor="#20FFFFFF"
                            Padding="12,6"
                            HorizontalOptions="Start"
                            Margin="0,8,0,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{0:dddd, MMMM dd}'}"
                               FontFamily="DMSansMedium"
                               FontSize="12"
                               TextColor="White" />
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Content area overlapping header -->
            <VerticalStackLayout Padding="20,0,20,24" Spacing="20" Margin="0,-24,0,0">

                <!-- Quick Actions Card -->
                <Border x:Name="QuickActionsCard"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20"
                        Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Quick Actions" Style="{StaticResource Heading3}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                            <!-- Stat Card 1 -->
                            <Border BackgroundColor="{StaticResource Surface3}" Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="📚" FontSize="28" />
                                    <Label Text="My Courses"
                                           FontFamily="JakartaSemiBold" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="View enrolled courses"
                                           Style="{StaticResource Caption}" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Stat Card 2 -->
                            <Border Grid.Column="1" BackgroundColor="{StaticResource Surface3}" Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="📋" FontSize="28" />
                                    <Label Text="Documents"
                                           FontFamily="JakartaSemiBold" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Upload and manage"
                                           Style="{StaticResource Caption}" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Stat Card 3 -->
                            <Border Grid.Row="1" BackgroundColor="{StaticResource Surface3}" Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="📅" FontSize="28" />
                                    <Label Text="Schedule"
                                           FontFamily="JakartaSemiBold" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Upcoming events"
                                           Style="{StaticResource Caption}" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Stat Card 4 -->
                            <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{StaticResource Surface3}" Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="💬" FontSize="28" />
                                    <Label Text="Support"
                                           FontFamily="JakartaSemiBold" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Get help"
                                           Style="{StaticResource Caption}" />
                                </VerticalStackLayout>
                            </Border>

                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Onboarding Progress Card -->
                <Border x:Name="ProgressCard"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20"
                        Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Onboarding Progress"
                                   Style="{StaticResource Heading3}" />
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource WarningLight}"
                                    Padding="10,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="In Progress"
                                       FontFamily="JakartaSemiBold"
                                       FontSize="11"
                                       TextColor="{StaticResource Warning}" />
                            </Border>
                        </Grid>

                        <!-- Progress Bar -->
                        <Grid HeightRequest="8">
                            <BoxView BackgroundColor="{StaticResource Surface3}"
                                     CornerRadius="4" />
                            <BoxView BackgroundColor="{StaticResource Primary}"
                                     CornerRadius="4"
                                     HorizontalOptions="Start"
                                     WidthRequest="120" />
                        </Grid>
                        <Label Text="2 of 5 steps completed"
                               Style="{StaticResource BodySmall}" />

                        <!-- Steps -->
                        <VerticalStackLayout Spacing="12">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="✅" FontSize="18" />
                                <Label Text="Email Verification"
                                       FontFamily="DMSansMedium"
                                       TextColor="{StaticResource Success}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="✅" FontSize="18" />
                                <Label Text="Profile Created"
                                       FontFamily="DMSansMedium"
                                       TextColor="{StaticResource Success}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="⏳" FontSize="18" />
                                <Label Text="Document Upload"
                                       FontFamily="DMSansMedium"
                                       TextColor="{StaticResource TextSecondary}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="⬜" FontSize="18" />
                                <Label Text="Course Selection"
                                       FontFamily="DMSansMedium"
                                       TextColor="{StaticResource TextMuted}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="⬜" FontSize="18" />
                                <Label Text="Payment"
                                       FontFamily="DMSansMedium"
                                       TextColor="{StaticResource TextMuted}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Announcements Card -->
                <Border x:Name="AnnouncementsCard"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20"
                        Opacity="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#145B5BD6" Offset="0,4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Announcements" Style="{StaticResource Heading3}" />

                        <Border BackgroundColor="{StaticResource InfoLight}"
                                Stroke="{StaticResource Info}" StrokeThickness="1"
                                Padding="16">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="📢 Welcome to the platform!"
                                       FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{StaticResource Info}" />
                                <Label Text="Complete your onboarding steps to get started with your courses. We're excited to have you here!"
                                       Style="{StaticResource BodySmall}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
